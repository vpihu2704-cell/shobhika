def make_gauge(title, value, min_val, max_val, warning, danger):
    color = "green"
    if value > danger:
        color = "red"
    elif value > warning:
        color = "orange"
    return go.Figure(
        data=[go.Indicator(
            mode="gauge+number",
            value=value,
            title={"text": title, "font": {"color": "white"}},
            gauge={
                "axis": {"range": [min_val, max_val]},
                "bar": {"color": color},
                "steps": [
                    {"range": [min_val, warning], "color": "#1a1a1a"},
                    {"range": [warning, danger], "color": "#3d2b00"},
                    {"range": [danger, max_val], "color": "#3d0000"},
                ]
            }
        )],
        layout=go.Layout(
            paper_bgcolor="#111",
            font={"color": "white"},
            height=250
        )
    )

def make_chart(title, times, values, color):
    return go.Figure(
        data=[go.Scatter(
            x=times, y=values,
            mode="lines+markers",
            line={"color": color, "width": 2},
            marker={"size": 10},
            name=title
        )],
        layout=go.Layout(
            title=title,
            paper_bgcolor="#111",
            plot_bgcolor="#222",
            font={"color": "white"},
            xaxis={"title": "Time"},
            yaxis={"title": title},
            height=250
        )
    )

