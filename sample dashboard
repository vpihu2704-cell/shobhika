from flask import Flask, request, jsonify
from flask_cors import CORS
import sqlite3
import datetime

app = Flask(__name__)
CORS(app)

def init_db():
    conn = sqlite3.connect("iot_data.db")
    cursor = conn.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS sensor_data (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            timestamp TEXT,
            temperature REAL,
            humidity REAL,
            pressure REAL,
            altitude REAL,
            gas REAL,
            distance REAL
        )
    ''')
    conn.commit()
    conn.close()
    print("Database ready!")

@app.route("/API/UploadData", methods=["POST"])
def upload_data():
    data = request.json
    conn = sqlite3.connect("iot_data.db")
    cursor = conn.cursor()
    cursor.execute('''
        INSERT INTO sensor_data (timestamp, temperature, humidity, pressure, altitude, gas, distance)
        VALUES (?, ?, ?, ?, ?, ?, ?)
    ''', (
        datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        data.get("temperature", 0),
        data.get("humidity", 0),
        data.get("pressure", 0),
        data.get("altitude", 0),
        data.get("gas", 0),
        data.get("distance", 0)
    ))
    conn.commit()
    conn.close()
    print(f"Data saved: {data}")
    return jsonify({"Response": "Success", "Message": "Data saved!"})

@app.route("/API/GetData", methods=["GET"])
def get_data():
    conn = sqlite3.connect("iot_data.db")
    cursor = conn.cursor()
    cursor.execute('''
        SELECT timestamp, temperature, humidity, pressure, altitude, gas, distance
        FROM sensor_data
        ORDER BY id DESC LIMIT 20
    ''')
    rows = cursor.fetchall()
    conn.close()
    result = []
    for row in rows:
        result.append({
            "timestamp": row[0],
            "temperature": row[1],
            "humidity": row[2],
            "pressure": row[3],
            "altitude": row[4],
            "gas": row[5],
            "distance": row[6]
        })
    return jsonify(result)

if __name__ == "__main__":
    init_db()
    print("API running at http://127.0.0.1:5000")
    app.run(debug=False, port=5000)


