import requests
import random
import time

API_URL = "http://127.0.0.1:5000/API/UploadData"

print("=== Revol IoT Sensor Simulator ===")
print("Sending data to API every 5 seconds...")
print("Press Ctrl+C to stop\n")

while True:
    data = {
        "temperature": round(random.uniform(20, 45), 2),
        "humidity": round(random.uniform(30, 90), 2),
        "pressure": round(random.uniform(980, 1050), 2),
        "current": round(random.uniform(4, 20), 2)
    }
    try:
        response = requests.post(API_URL, json=data)
        result = response.json()
        print(f"Sent: {data}")
        print(f"Response: {result}\n")
    except Exception as e:
        print(f"Error: {e}")

    time.sleep(5)
