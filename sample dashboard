def update_dashboard(n):
    print(f"Triggered! n={n}")
    try:
        r = requests.get("http://127.0.0.1:5000/API/GetData", timeout=5)
        data = r.json()
        print(f"Records: {len(data)}")
    except Exception as e:
        print(f"ERROR: {e}")
        data = []

    if not data:
        empty = go.Figure()
        return (empty,)*12 + ("No data yet...", "")

    last2 = data[:2]
    times = [d["timestamp"] for d in reversed(last2)]
    temps = [d["temperature"] for d in reversed(last2)]
    hums = [d["humidity"] for d in reversed(last2)]
    press = [d["pressure"] for d in reversed(last2)]
    alts = [d["altitude"] for d in reversed(last2)]
    gases = [d["gas"] for d in reversed(last2)]
    dists = [d["distance"] for d in reversed(last2)]

    latest = data[0]
    temp = latest.get("temperature", 0)
    hum = latest.get("humidity", 0)
    pres = latest.get("pressure", 0)
    alt = latest.get("altitude", 0)
    gas = latest.get("gas", 0)
    dist = latest.get("distance", 0)

    # Alerts
    alerts = []
    limits = {
        "temperature": (35, 40),
        "humidity": (70, 85),
        "pressure": (1040, 1045),
        "altitude": (100, 200),
        "gas": (1000, 2000),
        "distance": (20, 10)
    }
    values = {
        "temperature": temp, "humidity": hum,
        "pressure": pres, "altitude": alt,
        "gas": gas, "distance": dist
    }
    for sensor, (warning, danger) in limits.items():
        value = values[sensor]
        if value > danger:
            alerts.append(f"🔴 {sensor.upper()}: {value} — DANGER!")
            if not email_sent[sensor]:
                send_email(sensor, value, "DANGER")
                email_sent[sensor] = True
        elif value > warning:
            alerts.append(f"⚠️ {sensor.upper()}: {value} — WARNING!")
            if not email_sent[sensor]:
                send_email(sensor, value, "WARNING")
                email_sent[sensor] = True
        else:
            email_sent[sensor] = False

    if alerts:
        banner = html.Div([html.H3(a, style={"color": "red"}) for a in alerts])
    else:
        banner = html.H3("✅ All Sensors Normal", style={"color": "green"})

    current_vals = html.Div([
        html.Span(f"🌡️ Temp: {temp}°C  ", style={"color": "red"}),
        html.Span(f"💧 Humidity: {hum}%  ", style={"color": "cyan"}),
        html.Span(f"🔵 Pressure: {pres}hPa  ", style={"color": "lightgreen"}),
        html.Span(f"🏔️ Altitude: {alt}m  ", style={"color": "white"}),
        html.Span(f"💨 Gas: {gas}  ", style={"color": "orange"}),
        html.Span(f"📡 Distance: {dist}cm", style={"color": "yellow"}),
    ])

    return (
        make_gauge("Temperature °C", temp, 0, 50, 35, 40),
        make_gauge("Humidity %", hum, 0, 100, 70, 85),
        make_gauge("Pressure hPa", pres, 950, 1050, 1040, 1045),
        make_gauge("Altitude m", alt, 0, 300, 100, 200),
        make_gauge("Gas Level", gas, 0, 4095, 1000, 2000),
        make_gauge("Distance cm", dist, 0, 100, 20, 10),
        make_chart("Temperature °C", times, temps, "red"),
        make_chart("Humidity %", times, hums, "cyan"),
        make_chart("Pressure hPa", times, press, "lightgreen"),
        make_chart("Altitude m", times, alts, "white"),
        make_chart("Gas Level", times, gases, "orange"),
        make_chart("Distance cm", times, dists, "yellow"),
        current_vals,
        banner
    )

